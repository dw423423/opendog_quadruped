collisions {
    collisionSpheres {
        [0] "Lfl3_knee, 0.08"
        [1] "Lfr3_knee, 0.08"
        [2] "Lrl3_knee, 0.08"
        [3] "Lrr3_knee, 0.08"
    }
    collisionOffsets {
        (0,0) -0.055
        (0,1) 0.0
        (0,2) 0.0
        (1,0) -0.055
        (1,1) 0.0
        (1,2) 0.0
        (2,0) -0.055
        (2,1) 0.0
        (2,2) 0.0
        (3,0) -0.055
        (3,1) 0.0
        (3,2) 0.0
    }
