     (2,0)   15.7079632679  ; Jfl3_knee
     (3,0)   15.7079632679  ; Jfr1_hip_roll
     (4,0)   15.7079632679  ; Jfr2_hip_pitch
     (5,0)   15.7079632679  ; Jfr3_knee
     (6,0)   15.7079632679  ; Jrl1_hip_roll
     (7,0)   15.7079632679  ; Jrl2_hip_pitch
     (8,0)   15.7079632679  ; Jrl3_knee
